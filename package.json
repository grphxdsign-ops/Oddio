{
  "name": "oddioai",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.107.0",
    "expo": "~56.0.8",
    "expo-audio": "~56.0.11",
    "expo-dev-client": "~56.0.18",
    "expo-status-bar": "~56.0.4",
    "oddio-audio-session": "file:modules/oddio-audio-session",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.2",
    "detox": "^20.51.3",
    "jest": "^29.7.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke-test.ts",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:metro": "expo start --dev-client --localhost"
  },
  "private": true
}
